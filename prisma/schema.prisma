generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WebsiteStatus {
  NEW
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

enum LeadStatus {
  NEW
  CONTACTED
  REPLIED
  ENGAGED
  CONVERTED
}

enum ProcessingJobStatus {
  PENDING
  ACTIVE
  COMPLETED
  FAILED
}

enum AnalysisStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum ContactType {
  EMAIL
  PHONE
}

enum ContactSource {
  MAILTO
  TEL
  FOOTER
  HEADER
  CONTACT_PAGE
  BODY
}

enum ExtractionStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  NO_CONTACTS_FOUND
}

enum OutreachStatus {
  PENDING
  GENERATING
  GENERATED
  FAILED
}

enum OutreachProviderType {
  TEMPLATE
  OPENAI
  ANTHROPIC
  CUSTOM
}

enum EmailDeliveryStatus {
  PENDING
  SENDING
  SENT
  FAILED
}

enum EmailActivityType {
  QUEUED
  SENDING
  SENT
  FAILED
  RETRY
  CANCELLED
}

enum FollowUpStatus {
  PENDING
  SCHEDULED
  SENT
  CANCELLED
  SKIPPED
}

enum ReplyStatus {
  PENDING
  RECEIVED
  FAILED
}

enum MessageDirection {
  OUTBOUND
  INBOUND
}

model IntakeBatch {
  id             String    @id @default(cuid())
  batchCode      String    @unique
  totalLines     Int
  validCount     Int
  insertedCount  Int
  duplicateCount Int
  invalidCount   Int
  createdAt      DateTime  @default(now())
  websites       Website[]

  @@index([createdAt(sort: Desc)])
}

model Website {
  id             String        @id @default(cuid())
  rawUrl         String
  normalizedUrl  String        @unique
  domain         String
  status         WebsiteStatus @default(NEW)
  batchId        String
  batch          IntakeBatch   @relation(fields: [batchId], references: [id], onDelete: Cascade)
  validationNote String?
  leadStatus     LeadStatus    @default(NEW)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  jobs           ProcessingJob[]
  analysis          WebsiteAnalysis?
  contactExtraction ContactExtraction?
  contacts          Contact[]
  outreachDrafts    OutreachDraft[]
  emailMessages     EmailMessage[]
  followUpSchedules FollowUpSchedule[]
  replies           Reply[]
  followUpHistory   FollowUpHistory[]
  conversations      Conversation[]

  @@index([domain])
  @@index([status])
  @@index([batchId])
  @@index([leadStatus])
  @@index([createdAt(sort: Desc)])
}

model ProcessingJob {
  id          String              @id @default(cuid())
  websiteId   String
  website     Website             @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  jobType     String              @default("pipeline")
  status      ProcessingJobStatus @default(PENDING)
  payload     Json?
  attempts    Int                 @default(0)
  maxAttempts Int                 @default(3)
  priority    Int                 @default(0)
  currentStage String?
  lastError   String?
  lockedAt    DateTime?
  lockToken   String?
  scheduledAt DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  startedAt   DateTime?
  completedAt DateTime?

  @@index([status])
  @@index([websiteId])
  @@index([createdAt(sort: Desc)])
  @@index([scheduledAt])
  @@index([priority(sort: Desc), createdAt(sort: Asc)])
}

model WebsiteAnalysis {
  id                  String         @id @default(cuid())
  websiteId           String         @unique
  website             Website        @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  status              AnalysisStatus @default(PENDING)
  performanceScore    Int?
  accessibilityScore  Int?
  seoScore            Int?
  bestPracticesScore  Int?
  overallScore        Int?
  lighthouseVersion   String?
  formFactor          String?
  finalUrl            String?
  pageTitle           String?
  fetchTimeMs         Int?
  durationMs          Int?
  rawReport           Json?
  findings            Json           @default("[]")
  executiveSummary    String?
  errorMessage        String?
  analyzedAt          DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@index([status])
  @@index([analyzedAt(sort: Desc)])
  @@index([overallScore])
}

model ContactExtraction {
  id             String           @id @default(cuid())
  websiteId      String           @unique
  website        Website          @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  status         ExtractionStatus @default(PENDING)
  contactPageUrl String?
  pagesScanned   Int              @default(0)
  emailCount     Int              @default(0)
  phoneCount     Int              @default(0)
  errorMessage   String?
  extractedAt    DateTime?
  durationMs     Int?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([status])
  @@index([extractedAt(sort: Desc)])
}

model Contact {
  id             String        @id @default(cuid())
  websiteId      String
  website        Website       @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  type           ContactType
  value          String
  displayValue   String?
  source         ContactSource
  sourceUrl      String
  contactPageUrl String?
  confidence     Int           @default(50)
  isPrimary      Boolean       @default(false)
  createdAt      DateTime      @default(now())

  @@unique([websiteId, type, value])
  @@index([websiteId])
  @@index([type])
}

model OutreachDraft {
  id              String               @id @default(cuid())
  websiteId       String
  website         Website              @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  version         Int                  @default(1)
  status          OutreachStatus       @default(PENDING)
  subject         String?
  body            String?
  recipientEmail  String?
  recipientName   String?
  provider        OutreachProviderType @default(TEMPLATE)
  providerModel   String?
  promptVersion   String               @default("1.0")
  inputSnapshot   Json?
  generationMeta  Json?
  errorMessage    String?
  generatedAt     DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@unique([websiteId, version])
  @@index([websiteId, version(sort: Desc)])
  @@index([status])
  emailMessages EmailMessage[]
}

model EmailMessage {
  id              String              @id @default(cuid())
  websiteId       String
  website         Website             @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  outreachDraftId String?
  outreachDraft   OutreachDraft?      @relation(fields: [outreachDraftId], references: [id], onDelete: SetNull)
  status          EmailDeliveryStatus @default(PENDING)
  fromAddress     String
  toAddress       String
  toName          String?
  subject         String
  bodyText        String
  bodyHtml        String?
  messageId       String?
  attempts        Int                 @default(0)
  maxAttempts     Int                 @default(3)
  lastError       String?
  queuedAt        DateTime            @default(now())
  sentAt          DateTime?
  failedAt        DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  activities      EmailActivity[]
  initialFollowUpSchedules FollowUpSchedule[] @relation("FollowUpInitialEmail")
  followUpSchedules FollowUpSchedule[] @relation("FollowUpScheduleMessages")
  replies         Reply[]
  followUpHistory FollowUpHistory[]
  conversations   Conversation[]

  @@index([websiteId])
  @@index([outreachDraftId])
  @@index([status])
  @@index([queuedAt(sort: Desc)])
}

model EmailActivity {
  id             String           @id @default(cuid())
  emailMessageId String
  emailMessage   EmailMessage     @relation(fields: [emailMessageId], references: [id], onDelete: Cascade)
  type           EmailActivityType
  message        String
  metadata       Json?
  createdAt      DateTime         @default(now())

  @@index([emailMessageId])
  @@index([createdAt(sort: Desc)])
}

model FollowUpSchedule {
  id              String         @id @default(cuid())
  websiteId       String
  website         Website        @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  initialEmailId  String
  initialEmail    EmailMessage   @relation("FollowUpInitialEmail", fields: [initialEmailId], references: [id], onDelete: Cascade)
  sequence        Int            @default(1)
  scheduledDays   Int
  status          FollowUpStatus @default(PENDING)
  scheduledFor    DateTime?
  sentAt          DateTime?
  cancelledAt     DateTime?
  skippedReason   String?
  stoppedDueToReply Boolean      @default(false)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  followUpMessages EmailMessage[] @relation("FollowUpScheduleMessages")
  history          FollowUpHistory[]

  @@unique([websiteId, sequence])
  @@index([websiteId])
  @@index([initialEmailId])
  @@index([status])
  @@index([scheduledFor])
  @@index([sequence])
}

model Reply {
  id              String       @id @default(cuid())
  websiteId       String
  website         Website      @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  originalEmailId String
  originalEmail   EmailMessage @relation(fields: [originalEmailId], references: [id], onDelete: Cascade)
  status          ReplyStatus  @default(PENDING)
  replySubject    String?
  replyBody       String?
  replyFrom       String?
  replyDate       DateTime?
  errorMessage    String?
  detectedAt      DateTime     @default(now())
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  conversations   Conversation[]

  @@index([websiteId])
  @@index([originalEmailId])
  @@index([status])
  @@index([detectedAt(sort: Desc)])
}

model FollowUpHistory {
  id              String        @id @default(cuid())
  websiteId       String
  website         Website       @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  scheduleId      String?
  schedule        FollowUpSchedule? @relation(fields: [scheduleId], references: [id], onDelete: SetNull)
  emailMessageId  String
  emailMessage    EmailMessage  @relation(fields: [emailMessageId], references: [id], onDelete: Cascade)
  sequence        Int
  followUpType    String
  subject         String
  body            String
  sentAt          DateTime
  createdAt       DateTime      @default(now())

  @@index([websiteId])
  @@index([scheduleId])
  @@index([emailMessageId])
  @@index([sentAt(sort: Desc)])
}

model Conversation {
  id              String            @id @default(cuid())
  websiteId       String
  website         Website           @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  direction       MessageDirection
  subject         String
  body            String
  fromAddress     String
  toAddress       String
  messageId       String?
  inReplyTo       String?
  timestamp       DateTime
  emailMessageId  String?
  emailMessage    EmailMessage?    @relation(fields: [emailMessageId], references: [id], onDelete: SetNull)
  replyId         String?
  reply           Reply?           @relation(fields: [replyId], references: [id], onDelete: SetNull)
  createdAt       DateTime          @default(now())

  @@index([websiteId])
  @@index([direction])
  @@index([timestamp(sort: Desc)])
  @@index([emailMessageId])
  @@index([replyId])
}
